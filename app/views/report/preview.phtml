<script>                                                                      
    function setLang(lang) {
        document.querySelectorAll('.lang-en').forEach(el => el.classList.toggle('d-none', lang === 'de'));
        document.querySelectorAll('.lang-de').forEach(el => el.classList.toggle('d-none', lang === 'en'));   
      
        document.getElementById('btn-en').className = lang === 'en' ? 'btn btn-dark btn-sm' : 'btn btn-outline-dark btn-sm'; 
        document.getElementById('btn-de').className = lang === 'de' ? 'btn btn-dark btn-sm' : 'btn btn-outline-dark btn-sm';                                   
    }               
</script>                                      